        {
            "name": "Invoices",
            "item": [
                {
                    "name": "Create Invoice",
                    "event": [
                        {
                            "listen": "prerequest",
                            "script": {
                                "exec": [
                                    "var ts = Date.now();",
                                    "var ref = 'FAC-' + ts;",
                                    "pm.collectionVariables.set('reference_code', ref);"
                                ],
                                "type": "text/javascript"
                            }
                        },
                        {
                            "listen": "test",
                            "script": {
                                "exec": [
                                    "var jsonData = pm.response.json();",
                                    "if (jsonData && jsonData.number) {",
                                    "    pm.collectionVariables.set('invoice_number', jsonData.number);",
                                    "}"
                                ],
                                "type": "text/javascript"
                            }
                        }
                    ],
                    "request": {
                        "method": "POST",
                        "header": [
                            {
                                "key": "X-API-Key",
                                "value": "{{api_key}}",
                                "type": "text"
                            },
                            {
                                "key": "X-Factus-Token",
                                "value": "{{factus_token}}",
                                "type": "text"
                            }
                        ],
                        "body": {
                            "mode": "raw",
                            "raw": "{\n    \"document\": \"invoice\",\n    \"numbering_range_id\": 8,\n    \"reference_code\": \"{{reference_code}}\",\n    \"observation\": \"Prueba de factura\",\n    \"payment_method\": \"cash_payment\",\n    \"payment_form\": \"cash\",\n    \"customer\": {\n        \"identification_document_type\": \"CC\",\n        \"identification\": \"123456789\",\n        \"names\": \"Juan Perez\",\n        \"address\": \"Calle 123\",\n        \"email\": \"juan@example.com\",\n        \"phone\": \"3001234567\",\n        \"municipality_id\": 980,\n        \"legal_organization\": \"person\",\n        \"tribute\": \"ZZ\"\n    },\n    \"items\": [\n        {\n            \"code_reference\": \"PROD-001\",\n            \"name\": \"Producto de prueba\",\n            \"quantity\": 1,\n            \"price\": \"10000.00\",\n            \"discount_rate\": \"0.00\",\n            \"tax_rate\": \"19.00\",\n            \"unit_measure\": \"94\",\n            \"standard_code\": \"1\",\n            \"is_excluded\": 0,\n            \"tribute\": \"IVA\"\n        }\n    ]\n}",
                            "options": {
                                "raw": {
                                    "language": "json"
                                }
                            }
                        },
                        "url": {
                            "raw": "{{base_url}}/invoices/",
                            "host": [
                                "{{base_url}}"
                            ],
                            "path": [
                                "invoices",
                                ""
                            ]
                        }
