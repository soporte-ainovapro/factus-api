# Factus API — variables de entorno requeridas
# Copia este archivo a .env y rellena los valores reales

# URL base de Factus (sandbox o producción)
FACTUS_BASE_URL=https://api-sandbox.factus.com.co

# Credenciales OAuth de Factus (obtenidas en el panel de Factus)
FACTUS_CLIENT_ID=your-client-id-here
FACTUS_CLIENT_SECRET=your-client-secret-here

# Clave secreta para firmar los JWT locales (genera una con: openssl rand -base64 32)
SECRET_KEY=your-secret-key-here

# Entorno: "development" habilita /docs y /redoc; "production" los deshabilita
ENVIRONMENT=development

# Orígenes permitidos para CORS (JSON array o lista separada por comas)
CORS_ORIGINS=["http://localhost:5173","http://127.0.0.1:5173"]
